{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@pumpkinredbean/tiny-agent-runtime",
  "version": "0.0.0",
  "description": "Standalone runtime for agent providers and loop orchestration",
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "login:codex": "bun run src/auth/codex.cli.ts",
    "login:copilot": "bun run src/auth/copilot.cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test src",
    "sample": "bun run examples/browser-sample/server.ts",
    "smoke": "bun run src/smoke/index.ts",
    "smoke:copilot": "bun run src/smoke/copilot.ts",
    "smoke:codex": "bun run src/smoke/codex.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth/contracts.ts",
    "./auth/codex": "./src/auth/codex.ts",
    "./auth/copilot": "./src/auth/copilot.ts",
    "./auth/store": "./src/auth/store.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/node": "22.13.9",
    "typescript": "5.8.2"
  }
}
